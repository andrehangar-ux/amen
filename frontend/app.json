{
  "expo": {
    "name": "Amen!",
    "slug": "amen-app",
    "version": "1.1.22",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "amen",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.amen.myapp"
    },
    "android": {
      "package": "com.amen.myapp",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#4A7C59"
      },
      "edgeToEdgeEnabled": false,
      "permissions": []
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#4A7C59"
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "amen-spiritual-app"
      }
    }
  }
}
